(function(window) {

  if (!!window.IKIcookie) {
    return window.IKIcookie;
  }

  var document = window.document;
  var textContent = 'textContent' in document.body;
  var olderIE = (!textContent ? true : false);
  
  var IKIcookie = (function() {

    var cookieName = 'mrw_cookielaw';
    var cookieConsentId = 'mrw_cookielaw_banner';
    var dismissLinkId = 'mrw_cookielaw_dismiss';
    var policyLinkId = 'mrw_cookielaw_policy';
    
    var reloadAfterConsent = false; // forzo il reload della pagina dopo l'accettazione
    var subDomainCookie = true; // imposto un cookie su tutto il dominio
    
    var scrollStartPos = 0;
    var screenWidth = screen.width;

    function _getDomainName() {
      var domain;
      var host = location.hostname;
      var domain_array = host.split('.');
      var domain_parts = domain_array.length;
      if (domain_parts == 2) domain = host;    
      else{
        domain = domain_array[domain_parts-2] + '.' + domain_array[domain_parts-1]; 
      }
      return domain;
    }

    function _setElementText(ele, text) {
      if (textContent) {
        ele.textContent = text;
      }else{
        ele.innerText = text;
      }
    }

    function _getScroll() {
      var px = 0;
      if (typeof(window.pageYOffset) == 'number') px = window.pageYOffset;
      else if (document.body && document.body.scrollTop) px = document.body.scrollTop;
      else if (document.documentElement && document.documentElement.scrollTop) px = document.documentElement.scrollTop;
      return px;        
    }

    function _addEvent(ele, eve, fnc) {
      if (ele.addEventListener) {
        ele.addEventListener(eve, fnc, false);
      }
      else if (ele.attachEvent) {
        if (eve == 'DOMContentLoaded') eve = 'readystatechange';
        ele.attachEvent('on' + eve, fnc);
      }else{
        if (eve == 'DOMContentLoaded') eve = 'load';
        ele['on' + eve] = fnc;
      }
    }

    function _removeEvent(ele, eve, fnc) {
      if (ele.removeEventListener) {
        ele.removeEventListener(eve, fnc, false);
      }
      else if (ele.detachEvent) {
        ele.detachEvent('on' + eve, fnc);
      }else{
        ele['on' + eve] = null;
      }
    }

    function _createHeaderElement(cookieText, dismissText, linkText, linkHref) {
      var cookieConsentElement = document.createElement('div');
      cookieConsentElement.id = cookieConsentId;
      cookieConsentElement.style.cssText = 'position: fixed; width: 100%; background-color: ' + (olderIE ? '#444' : 'rgba(0,0,0,0.7)') + ';'
                                         + 'margin: 0; left: 0; top: 0; padding: 10px 0; z-index: 1000;';
      
      var cookieConsentContainer = document.createElement('div');
      cookieConsentContainer.style.cssText = 'position: relative; width: ' + (screenWidth >= 980 ? '980px' : '98%') + '; margin: 0 auto;';
      cookieConsentContainer.appendChild(_createConsentText(cookieText));

      cookieConsentElement.appendChild(cookieConsentContainer);
      
      if (!!linkText && !!linkHref) {
        cookieConsentContainer.appendChild(_createPolicyLink(linkText, linkHref));
      }
      cookieConsentContainer.appendChild(_createDismissLink(dismissText));
      return cookieConsentElement;
    }

    function _createConsentText(cookieText) {
      var consentText = document.createElement('span');
      consentText.style.cssText = 'display: block; width: ' + (screenWidth >= 980 ? '800px' : '70%') + '; line-height: 20px; color: #FFF;'
                                + 'font-family: verdana, arial, tahoma, sans-serif; font-size: 12px;';
      _setElementText(consentText, cookieText);
      return consentText;
    }

    function _createDismissLink(dismissText) {
      var dismissLink = document.createElement('a');
      _setElementText(dismissLink, dismissText);
      dismissLink.id = dismissLinkId;
      dismissLink.href = '#';
      dismissLink.style.cssText = 'position: absolute; top: 0; right: 0; display: block; width: ' + (screenWidth >= 980 ? '140px' : '28%') + '; line-height: 30px;'
                                + 'color: #FF9900; text-align: center; font-size: 14px; font-weight: bold; text-decoration: none;';
      return dismissLink;
    }

    function _createPolicyLink(linkText, linkHref) {
      var infoLink = document.createElement('a');
      _setElementText(infoLink, linkText);
      infoLink.id = policyLinkId;
      infoLink.href = linkHref;
      infoLink.target = '_blank';
      infoLink.style.cssText = 'position: absolute; top: 30px; right: 0; display: block; width: ' + (screenWidth >= 980 ? '140px' : '28%') + '; line-height: 30px;'
                             + 'color: #fff; text-align: center; font-size: 12px; text-decoration: underline;';
      return infoLink;
    }

    function _removeCookieBanner() {
      var cookieChoiceElement = document.getElementById(cookieConsentId);
      if (cookieChoiceElement != null) {
        cookieChoiceElement.parentNode.removeChild(cookieChoiceElement);
      }
      _removeEvent(window, 'scroll', _dismissAfterScroll);
    }

    function _saveUserPreference() {
      // Imposto la scadenza ad un anno
      var expiryDate = new Date();
      expiryDate.setFullYear(expiryDate.getFullYear() + 1);
      if (subDomainCookie) {
        document.cookie = cookieName + '=y; expires=' + expiryDate.toGMTString() + '; path=/; domain=' + _getDomainName();
      }else{
        document.cookie = cookieName + '=y; expires=' + expiryDate.toGMTString();
      }
    }

    function _acceptCookie() {
      _saveUserPreference();
      _removeCookieBanner();
      if (reloadAfterConsent) {
        window.location.reload();
      }else{
        return false;
      }
    }
    
    function _dismissAfterScroll() {
      var px = _getScroll();  
      if (px >= (scrollStartPos+50)) {
        _acceptCookie();
      }
    }

    function _shouldDisplayConsent() {
      // mostro il banner solo se il cookie non è settato
      return !document.cookie.match(new RegExp(cookieName + '=([^;]+)'));
    }

    function _showCookieBanner(cookieText, dismissText, linkText, linkHref, forceReload) {
      forceReload = forceReload || false;
      if (forceReload) {
        reloadAfterConsent = true;
      }
      if (_shouldDisplayConsent()) {
        _removeCookieBanner();
        scrollStartPos = _getScroll();
        var consentElement = _createHeaderElement(cookieText, dismissText, linkText, linkHref);
        var fragment = document.createDocumentFragment();
        fragment.appendChild(consentElement);
        document.body.appendChild(fragment.cloneNode(true));
        document.getElementById(dismissLinkId).onclick = _acceptCookie;
        var allLinks = document.getElementsByTagName('a');
        // creo un po'di event listener
        _addEvent(window,'scroll', _dismissAfterScroll);
        _addEvent(window,'load', function() {
          for (var i = 0; i < allLinks.length; i++) {
            if (allLinks[i].id != policyLinkId) {
              _addEvent(allLinks[i],'click', _saveUserPreference);
            }
          }            
        });       
      }
    }

    /*
    Funzione pubblica
    */
    function loadCookieBanner(cookieText, dismissText, linkText, linkHref, forceReload) {
      _addEvent(document,'DOMContentLoaded',function(event) {
        _showCookieBanner(cookieText, dismissText, linkText, linkHref, forceReload)
      }); 
    }
    
    var exports = {};
    exports.loadCookieBanner = loadCookieBanner;
    return exports;
  })();

  window.IKIcookie = IKIcookie;
  return IKIcookie;
})(this);
