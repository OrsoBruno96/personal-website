$(function(){
  $('#ikisclbtn li').each(function(i){    
    $(this).attr('id','scl'+$(this).data('scl')).append('<i class="' + $(this).data('scl') + '"></i><span>' + $(this).data('cnt') + '</span>')  
  }).click(function(){
    var lnk = $(this).parent().data('lnk');
    var tit = $(this).parent().data('tit');
    var scl = $(this).data('scl');
    var cnt = $(this).data('cnt');   
    var shareurl = '';
    var popup_width = 600;
    var popup_height = 400;
    if (scl == "fb") {
      if (window.FB) {
        FB.ui({
          method: 'feed',
          link: lnk,
        }, function(response){
            
        });
        return;        
      }else{
        shareurl = "https://www.facebook.com/sharer/sharer.php?u=" + encodeURIComponent(lnk);        
      }
    }       
    else if (scl == "tw") {
      shareurl = "https://twitter.com/intent/tweet?text="+encodeURIComponent(tit)+"&url="+encodeURIComponent(lnk);
      popup_height = 430;
    }
    else if (scl == "gp") {
      shareurl = "https://plus.google.com/share?url="+encodeURIComponent(lnk);
      popup_height = 600;
    }
    else if (scl == "ln") {
      shareurl = "http://www.linkedin.com/shareArticle?mini=true&url="+encodeURIComponent(lnk)+"&title="+encodeURIComponent(tit);
      popup_height = 570;
    }
    else return;
    var width  = popup_width,
        height = popup_height,
        left   = ($(window).width() - width)  / 2,
        top    = ($(window).height() - height) / 2,
        opts   = 'status=1' +
                 ',width='  + width +
                 ',height=' + height +
                 ',top='    + top +
                 ',left='   + left;
    var sclpp = window.open(shareurl, 'social', opts);
    var sclpptimer = setInterval(function() {   
      if (sclpp.closed) {  
        clearInterval(sclpptimer);  
        var cntagg = 0;
        $.post('/ajax.php', { 'do': 'sharecnt', 'pageurl': lnk, 'social': scl }, function(data){
          if (data.success == 1) {
            cntagg = data.output;
            if (cntagg > cnt) track_sociale(scl,lnk);
            $('#scl'+scl).data('cnt',cntagg).children('span').text(cntagg);
          } 
        },'json'); 
      }  
    }, 1000); 
  });
});
function track_sociale(social,pageurl) {
  $.post('/ajax.php', { 'do': 'track_social', 'social': social, 'pageurl': pageurl });
}