---
import type { Dictionary, Locale } from "../i18n";

interface Props {
  dictionary: Dictionary;
  locale: Locale;
  assetBase: string;
}

const { dictionary, locale, assetBase } = Astro.props;
const title = dictionary.site.title;
const alternateUrl = locale === "it" ? "../en/" : "../it/";
const alternateLang = locale === "it" ? "en" : "it";
const asset = (path: string) => `${assetBase}${path}`;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta
      name="viewport"
      content="width=device-width, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>{title}</title>
    <meta name="description" content={dictionary.site.description} />
    <meta name="author" content="Fabio Zoratti" />
    <link rel="shortcut icon" href={asset("/images/bruno_in_bici.ico")} type="image/x-icon" />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link rel="stylesheet" href={asset("/css/bootstrap.min.css")} />
    <link rel="stylesheet" href={asset("/style.css")} />
    <link rel="stylesheet" href={asset("/css/responsive.css")} />
    <link rel="stylesheet" href={asset("/css/custom.css")} />
    <script is:inline src={asset("/js/modernizr.js")}></script>
  </head>
  <body id="page-top" class="politics_version">
    <slot />

    <script is:inline src={asset("/js/all.js")}></script>
    <script is:inline src={asset("/js/jquery.easing.1.3.js")}></script>
    <script is:inline src={asset("/js/parallaxie.js")}></script>
    <script is:inline src={asset("/js/slick.min.js")}></script>
    <script is:inline src={asset("/js/animated-slider.js")}></script>
    <script is:inline src={asset("/js/jqBootstrapValidation.js")}></script>
    <script is:inline src={asset("/js/contact_me.js")}></script>
    <script is:inline src={asset("/js/custom.js")}></script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=UA-128275652-1"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", "UA-128275652-1");
    </script>
  </body>
</html>
